<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Mediar.Imaging.Arw</RootNamespace>
    <AssemblyName>Mediar.Imaging.Arw</AssemblyName>
    <IsPackable>true</IsPackable>
    <Description>Sony Alpha RAW (ARW) reader for the Mediar toolkit. ARW is a TIFF-based RAW container identified by the EXIF Make tag ("SONY"). Composes Mediar.Imaging.Tiff for the underlying IFD walk and pixel decode, walks SubIFDs to discover the full-resolution raw sensor mosaic, and exposes the parsed Sony-specific tag set (camera Make/Model, Software, DateTime, lens info from MakerNote-adjacent EXIF tags) into a structured ArwMetadata record. SR2 (Sony Raw v2) and earlier MRW are deferred.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Mediar.Imaging.Core\Mediar.Imaging.Core.csproj" />
    <ProjectReference Include="..\Mediar.Core\Mediar.Core.csproj" />
    <ProjectReference Include="..\Mediar.Imaging.Tiff\Mediar.Imaging.Tiff.csproj" />
  </ItemGroup>

</Project>

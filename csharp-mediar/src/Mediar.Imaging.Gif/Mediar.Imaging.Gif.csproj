<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Mediar.Imaging.Gif</RootNamespace>
    <AssemblyName>Mediar.Imaging.Gif</AssemblyName>
    <IsPackable>true</IsPackable>
    <Description>GIF87a / GIF89a / animated GIF reader for the Mediar toolkit. LZW decompression is delegated to Mediar.Codecs.Lzw so the same codec is shared with TIFF and any future PostScript / PDF reader.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Mediar.Imaging.Core\Mediar.Imaging.Core.csproj" />
    <ProjectReference Include="..\Mediar.Core\Mediar.Core.csproj" />
    <ProjectReference Include="..\Mediar.Codecs.Lzw\Mediar.Codecs.Lzw.csproj" />
  </ItemGroup>

</Project>

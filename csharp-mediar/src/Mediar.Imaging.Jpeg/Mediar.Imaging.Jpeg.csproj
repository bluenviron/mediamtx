<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Mediar.Imaging.Jpeg</RootNamespace>
    <AssemblyName>Mediar.Imaging.Jpeg</AssemblyName>
    <IsPackable>true</IsPackable>
    <Description>JPEG / JFIF / EXIF / MPO / THM reader + baseline decoder for the Mediar toolkit. EXIF/TIFF metadata extraction is delegated to Mediar.Imaging.Metadata so the same parser serves TIFF, HEIC, AVIF, DNG, CR3, and WebP readers.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Mediar.Imaging.Core\Mediar.Imaging.Core.csproj" />
    <ProjectReference Include="..\Mediar.Core\Mediar.Core.csproj" />
    <ProjectReference Include="..\Mediar.Imaging.Metadata\Mediar.Imaging.Metadata.csproj" />
  </ItemGroup>

</Project>
